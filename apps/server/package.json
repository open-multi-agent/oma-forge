{
  "name": "@oma-forge/server",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "npm run build -w @oma-forge/shared && npm run build -w @oma-forge/reporter && tsc",
    "start": "node dist/index.js",
    "lint": "npm run build -w @oma-forge/shared && npm run build -w @oma-forge/reporter && tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@oma-forge/reporter": "*",
    "@oma-forge/shared": "*",
    "@open-multi-agent/core": "^1.4.1",
    "fastify": "^5.3.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.1"
  }
}
